          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clientId\": \"postman_client\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/check",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3000",
          "path": [
            "check"
          ]
        }
      },
      "response": []
